<UserControl x:Class="AtomicWallet.Views.PortfolioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AtomicWallet.Controls"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PortfolioViewModel}">
    <Grid Margin="20,20,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Donut -->
        <Grid Grid.Row="0" Height="300" HorizontalAlignment="Center" Width="300">
            <controls:DonutChart Segments="{Binding Segments}" Thickness="16" />
            <TextBlock Style="{StaticResource Hero}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource Fiat}">
                        <Binding Path="TotalValue" />
                        <Binding Path="Symbol" Source="{StaticResource Fx}" />
                        <Binding Path="Rate" Source="{StaticResource Fx}" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <!-- Holdings header -->
        <Grid Grid.Row="1" Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <Style x:Key="SortHeader" TargetType="Button">
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="HorizontalAlignment" Value="Left" />
                    <Setter Property="Command" Value="{Binding SortCommand}" />
                </Style>
            </Grid.Resources>
            <Button Grid.Column="0" Style="{StaticResource SortHeader}" CommandParameter="Name">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=Name}" />
                            <TextBlock Text="Name" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=Name}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="1" Style="{StaticResource SortHeader}" CommandParameter="Balance">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=Balance}" />
                            <TextBlock Text="Balance" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=Balance}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Style="{StaticResource SortHeader}" CommandParameter="Value">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=Value}" />
                            <TextBlock Text="Value" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=Value}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="3" Style="{StaticResource SortHeader}" CommandParameter="Price">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=Price}" />
                            <TextBlock Text="Price" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=Price}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="4" Style="{StaticResource SortHeader}" CommandParameter="Change24h">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=Change24h}" />
                            <TextBlock Text="24h" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=Change24h}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="5" Style="{StaticResource SortHeader}" CommandParameter="PortfolioPercent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=PortfolioPercent}" />
                            <TextBlock Text="Portfolio" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=PortfolioPercent}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="6" Style="{StaticResource SortHeader}" CommandParameter="MarketCapB">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="{Binding SortAscending, Converter={StaticResource SortArrow}}"
                                  Visibility="{Binding SortColumn, Converter={StaticResource EqualsToVis}, ConverterParameter=MarketCapB}" />
                            <TextBlock Text="M. cap" FontSize="12"
                                       Foreground="{Binding SortColumn, Converter={StaticResource MatchBrush}, ConverterParameter=MarketCapB}" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Grid.Column="7" Text="7 days chart" Style="{StaticResource ColumnHeader}" />
        </Grid>

        <!-- Holdings rows -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Holdings}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="56" Background="Transparent" Cursor="Hand">
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.OpenAssetCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}" />
                        </Grid.InputBindings>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.4*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="32" Height="32">
                                <Border CornerRadius="16" Background="{Binding IconColor, Converter={StaticResource HexToBrush}}" />
                                <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}"
                                       Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                            <TextBlock Text="{Binding Name}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Balance, StringFormat=0.####}" FontSize="14" />
                            <TextBlock Text="{Binding Ticker}" Margin="5,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource Fiat}">
                                    <Binding Path="Value" />
                                    <Binding Path="Symbol" Source="{StaticResource Fx}" />
                                    <Binding Path="Rate" Source="{StaticResource Fx}" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="14"
                                   Foreground="{DynamicResource TextFaintBrush}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource Fiat}">
                                    <Binding Path="Price" />
                                    <Binding Path="Symbol" Source="{StaticResource Fx}" />
                                    <Binding Path="Rate" Source="{StaticResource Fx}" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="14"
                                   Text="{Binding Change24h, Converter={StaticResource SignedPercent}}"
                                   Foreground="{Binding Change24h, Converter={StaticResource ChangeBrush}}" />
                        <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding PortfolioPercent, StringFormat={}{0:N2}%}" />
                        <TextBlock Grid.Column="6" VerticalAlignment="Center" FontSize="14"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   Text="{Binding MarketCapB, StringFormat=${0:N2}B}" />
                        <controls:Sparkline Grid.Column="7" Height="34" Margin="0,0,16,0"
                                            Values="{Binding PriceHistory}"
                                            Stroke="{Binding SparkColor, Converter={StaticResource HexToBrush}}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
