<UserControl x:Class="AtomicWallet.Views.PolymarketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PolymarketViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Three-thirds tab bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding ShowMarketsCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Markets" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="1" Command="{Binding ShowPositionsCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Positions" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Command="{Binding ShowHistoryCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="History" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="2">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Markets tab -->
        <Grid Grid.Row="1"
              Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=0}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Summary strip -->
            <Grid Grid.Row="0" Margin="20,16,16,8">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Available to bet" Style="{StaticResource Caption}" />
                        <TextBlock Text="$0" Style="{StaticResource Heading}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Positions" Style="{StaticResource Caption}" />
                        <TextBlock Text="$0" Style="{StaticResource Heading}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="WITHDRAW" Style="{StaticResource PillSmall}" Width="130" Height="38"
                            Command="{Binding WithdrawCommand}" />
                    <Button Content="ADD FUNDS" Style="{StaticResource PillFilled}" Width="130" Height="38" Margin="12,0,0,0"
                            Command="{Binding AddFundsCommand}" />
                </StackPanel>
            </Grid>

            <!-- Search + categories -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,8,16,8">
                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8" Padding="12,6" Width="220">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconSearch}" Width="14" Height="14" Stretch="Uniform"
                              Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Search" Style="{StaticResource Caption}" Margin="8,0,0,0" />
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding Categories}" Margin="12,0,0,0" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectCategoryCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,16,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{Binding}" FontSize="12" FontWeight="Medium">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource MatchTextBrush}">
                                                    <Binding Path="DataContext.SelectedCategory"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    <Binding />
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Cards -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="14,8,14,8">
                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300" Margin="6" CornerRadius="10" Background="{DynamicResource SurfaceBrush}"
                                    Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="34" Height="34" CornerRadius="17"
                                                Background="{Binding IconColor, Converter={StaticResource HexToBrush}}">
                                            <TextBlock Text="{Binding Initial}" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="White" FontWeight="Bold" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Margin="12,0,0,0"
                                                   VerticalAlignment="Center" FontSize="13" Width="210" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ChanceText}" HorizontalAlignment="Right"
                                               FontWeight="Bold" Margin="0,12,0,0" />
                                    <ProgressBar Value="{Binding Chance}" Maximum="100" Height="6" Margin="0,6,0,0"
                                                 Background="{DynamicResource SurfaceAltBrush}"
                                                 Foreground="{DynamicResource AccentBlueBrush}" BorderThickness="0" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Cursor="Hand"
                                                Command="{Binding DataContext.BetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="8" Background="#16352B" Padding="0,8">
                                                        <TextBlock Text="{Binding YesLabel}" HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource PositiveBrush}" FontWeight="Medium" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Grid.Column="2" Cursor="Hand"
                                                Command="{Binding DataContext.BetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="8" Background="#3A2230" Padding="0,8">
                                                        <TextBlock Text="{Binding NoLabel}" HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource NegativeBrush}" FontWeight="Medium" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Positions / History empty -->
        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Caption}"
                   FontSize="14" Text="You have no open positions"
                   Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=1}" />
        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Caption}"
                   FontSize="14" Text="Your bets will appear here"
                   Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=2}" />
    </Grid>
</UserControl>
