<UserControl x:Class="AtomicWallet.Views.PerpsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PerpsViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Three-thirds tab bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding ShowMarketCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Market" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="1" Command="{Binding ShowPositionsCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Positions" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Command="{Binding ShowHistoryCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="History" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="2">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Market tab -->
        <Grid Grid.Row="1"
              Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=0}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Summary strip -->
            <Grid Grid.Row="0" Margin="20,16,16,8">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,40,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Trading Balance" Style="{StaticResource Caption}" />
                            <Path Data="{StaticResource IconInfo}" Width="12" Height="12" Stretch="Uniform"
                                  Fill="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="$0" Style="{StaticResource Heading}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Unrealized PNL" Style="{StaticResource Caption}" />
                            <Path Data="{StaticResource IconInfo}" Width="12" Height="12" Stretch="Uniform"
                                  Fill="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="$0" Style="{StaticResource Heading}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="WITHDRAW" Style="{StaticResource PillSmall}" Width="130" Height="38"
                            Command="{Binding WithdrawCommand}" />
                    <Button Content="ADD FUNDS" Style="{StaticResource PillFilled}" Width="130" Height="38" Margin="12,0,0,0"
                            Command="{Binding AddFundsCommand}" />
                </StackPanel>
            </Grid>

            <!-- Table header -->
            <Grid Grid.Row="1" Margin="20,8,16,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search market..." Style="{StaticResource ColumnHeader}" />
                <TextBlock Grid.Column="1" Text="Price" Style="{StaticResource ColumnHeader}" />
                <TextBlock Grid.Column="2" Text="24h Change" Style="{StaticResource ColumnHeader}" />
                <TextBlock Grid.Column="3" Text="24h Volume" Style="{StaticResource ColumnHeader}" />
                <TextBlock Grid.Column="4" Text="Funding Rate" Style="{StaticResource ColumnHeader}" />
                <TextBlock Grid.Column="5" Text="Open Interest" Style="{StaticResource ColumnHeader}" />
            </Grid>

            <!-- Rows -->
            <ListBox Grid.Row="2" ItemsSource="{Binding Markets}" Background="Transparent" BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent"><ContentPresenter /></Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource RowHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="20,0,16,0" Height="56">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Grid Width="30" Height="30">
                                    <Border CornerRadius="15" Background="{Binding IconColor, Converter={StaticResource HexToBrush}}">
                                        <TextBlock Text="{Binding Name, Converter={StaticResource Initial}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White" FontWeight="Bold" FontSize="12" />
                                    </Border>
                                    <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}"
                                           Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" />
                                </Grid>
                                <TextBlock Text="{Binding Name}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14" />
                                <Border Style="{StaticResource ChainBadge}" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Leverage}" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14"
                                       Text="{Binding Price, StringFormat=${0:N3}}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14"
                                       Text="{Binding Change24h, Converter={StaticResource SignedPercent}}"
                                       Foreground="{Binding Change24h, Converter={StaticResource ChangeBrush}}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="14"
                                       Foreground="{DynamicResource TextFaintBrush}" Text="{Binding Volume}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="14"
                                       Text="{Binding FundingRate, Converter={StaticResource SignedPercent}}"
                                       Foreground="{Binding FundingRate, Converter={StaticResource ChangeBrush}}" />
                            <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="14"
                                       Foreground="{DynamicResource TextFaintBrush}" Text="{Binding OpenInterest}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Positions / History empty -->
        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Caption}"
                   FontSize="14" Text="You have no open positions"
                   Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=1}" />
        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Caption}"
                   FontSize="14" Text="Your perps history will appear here"
                   Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=2}" />
    </Grid>
</UserControl>
