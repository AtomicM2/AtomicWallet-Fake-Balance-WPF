<Window x:Class="AtomicWallet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}"
        Title="Atomic Wallet 2.101.7" Height="900" Width="1500"
        Icon="/Assets/icon.ico"
        MinHeight="640" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        WindowStyle="None" AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#0E1426" BorderBrush="#16203A" BorderThickness="0,0,0,1">
            <Grid>
                <!-- Brand / title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Source="/Assets/logo.png" Width="18" Height="18"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Atomic Wallet" VerticalAlignment="Center" Margin="9,0,0,0"
                               FontSize="12.5" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="2.101.7" VerticalAlignment="Center" Margin="8,1,0,0"
                               FontSize="11" Foreground="{DynamicResource TextFaintBrush}" />
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Click="OnMinimize" Style="{StaticResource CaptionButton}" Height="38"
                            ToolTip="Minimize">
                        <Path Data="M0,0 H10" StrokeThickness="1.2" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Click="OnMaximize" Style="{StaticResource CaptionButton}" Height="38"
                            ToolTip="Maximize">
                        <Grid Width="10" Height="10">
                            <!-- Maximize glyph (when Normal) -->
                            <Rectangle x:Name="MaxGlyph" Width="10" Height="10" StrokeThickness="1.2"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <!-- Restore glyph (when Maximized) -->
                            <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                <Rectangle Width="8" Height="8" StrokeThickness="1.2"
                                           HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <Path Data="M2,0 H10 V8" StrokeThickness="1.2"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Grid>
                        </Grid>
                    </Button>
                    <Button Click="OnClose" Style="{StaticResource CaptionCloseButton}" Height="38"
                            ToolTip="Close">
                        <Path Data="M0,0 L10,10 M0,10 L10,0" StrokeThickness="1.2" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource BgBrush}"
                    BorderBrush="#16203A" BorderThickness="0,0,1,0">
                <DockPanel Margin="0,18,0,12">
                    <!-- Brand (our own original mark) -->
                    <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center"
                                Background="Transparent" Cursor="Hand">
                        <StackPanel.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding OpenPortfolioCommand}" />
                        </StackPanel.InputBindings>
                        <Image Source="/Assets/logo.png" Width="52" Height="52"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Atomic" HorizontalAlignment="Center" Margin="0,4,0,0"
                                   FontWeight="Bold" FontSize="16" />
                    </StackPanel>

                    <!-- Total widget -->
                    <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,14,0,0">
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="16"
                                Padding="12,5" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenPortfolioCommand}" />
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <!-- Circular sync/refresh mark (two rounded arcs) -->
                                <Ellipse Width="17" Height="17" VerticalAlignment="Center"
                                         Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"
                                         StrokeDashArray="9.3 2.5" StrokeDashCap="Round"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="64" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Medium">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource Fiat}">
                                            <Binding Path="Market.TotalValue" />
                                            <Binding Path="Symbol" Source="{StaticResource Fx}" />
                                            <Binding Path="Rate" Source="{StaticResource Fx}" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding SelectedCurrency}"
                                  Width="84" Height="28" Margin="0,4,0,0" HorizontalAlignment="Center"
                                  FontSize="12" />
                    </StackPanel>

                    <!-- Nav -->
                    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding NavItems}" Margin="0,18,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" Cursor="Hand" Height="44">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Background="Transparent">
                                                <Rectangle x:Name="bar" Width="3" HorizontalAlignment="Left"
                                                           Fill="{DynamicResource AccentBlueBrush}"
                                                           Visibility="Hidden" />
                                                <StackPanel Orientation="Horizontal" Margin="22,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <Path x:Name="ic" Width="20" Height="20" Stretch="Uniform"
                                                          Fill="{DynamicResource TextSecondaryBrush}"
                                                          Data="{Binding IconKey, Converter={StaticResource IconGeometry}}" />
                                                    <TextBlock x:Name="tx" Text="{Binding Title}"
                                                               Margin="14,0,0,0" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="tx" Property="Foreground"
                                                            Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Setter TargetName="ic" Property="Fill"
                                                            Value="{DynamicResource TextPrimaryBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter TargetName="bar" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="ic" Property="Fill"
                                                            Value="{DynamicResource AccentBlueBrush}" />
                                                    <Setter TargetName="tx" Property="Foreground"
                                                            Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Setter TargetName="tx" Property="FontWeight" Value="Medium" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Content host -->
            <Grid Grid.Column="1">
                <ContentControl Content="{Binding Navigation.CurrentPage}" />
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,28"
                        CornerRadius="10" Padding="20,12" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding Notifications.IsVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding Notifications.Message}" FontWeight="Medium" />
                </Border>
            </Grid>
        </Grid>

        <!-- Exit confirmation overlay -->
        <Grid Grid.RowSpan="2" Background="#AA0B0E1A"
              Visibility="{Binding ConfirmExitVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="44,30"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Close the wallet?" FontSize="16" FontWeight="Medium"
                               HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,26,0,0">
                        <Button Command="{Binding CancelExitCommand}" Width="110" Height="42"
                                Cursor="Hand" Margin="0,0,18,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="21" Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource NegativeBrush}" BorderThickness="1.5">
                                        <TextBlock Text="No" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource BorderBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ConfirmExitCommand}" Width="110" Height="42" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="21" Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource PositiveBrush}" BorderThickness="1.5">
                                        <TextBlock Text="Yes" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource BorderBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
