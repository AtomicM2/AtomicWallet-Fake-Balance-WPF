<UserControl x:Class="AtomicWallet.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:HistoryViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,14,16,10" Height="26">
            <Grid VerticalAlignment="Center" MaxWidth="220" HorizontalAlignment="Left">
                <TextBox Foreground="{DynamicResource TextPrimaryBrush}" Background="Transparent"
                         BorderThickness="0" FontSize="12"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Search" IsHitTestVisible="False" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Path Data="{StaticResource IconRefresh}" Width="18" Height="18" Stretch="Uniform"
                      Fill="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0" />
                <Path Data="{StaticResource IconExport}" Width="18" Height="18" Stretch="Uniform"
                      Fill="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0" />
                <Path Data="{StaticResource IconFilter}" Width="18" Height="18" Stretch="Uniform"
                      Fill="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Transactions -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Transactions}" Background="Transparent"
                 BorderThickness="0" HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="20,0,16,0">
                        <!-- Row -->
                        <Grid Height="72" Background="Transparent" Cursor="Hand">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.ToggleCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              CommandParameter="{Binding}" />
                            </Grid.InputBindings>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Grid Width="34" Height="34">
                                    <Border CornerRadius="17"
                                            Background="{Binding IconColor, Converter={StaticResource HexToBrush}}" />
                                    <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}"
                                           Width="34" Height="34" RenderOptions.BitmapScalingMode="HighQuality" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SignedAmount}" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource NegativeBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReceived}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Ticker}" Margin="6,0,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DirectionLabel}" Style="{StaticResource Caption}" />
                                <TextBlock Text="{Binding Address}" Foreground="{DynamicResource AccentBlueBrush}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="420" HorizontalAlignment="Left" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.yyyy, HH:mm'}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Width="16" Height="16"
                                      Stretch="Uniform" Fill="{DynamicResource PositiveBrush}" Margin="14,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Expanded detail -->
                        <StackPanel Margin="0,0,0,16"
                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="From" Style="{StaticResource Caption}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Address}" Foreground="{DynamicResource AccentBlueBrush}" />
                            <TextBlock Text="Hash" Style="{StaticResource Caption}" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Hash}" TextWrapping="Wrap" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextFaintBrush}" />
                            <Button Content="COPY" Style="{StaticResource PillSmall}" Width="110"
                                    HorizontalAlignment="Center" Margin="0,12,0,0"
                                    Command="{Binding DataContext.CopyCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding Hash}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
