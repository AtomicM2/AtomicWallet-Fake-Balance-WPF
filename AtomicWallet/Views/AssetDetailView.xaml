<UserControl x:Class="AtomicWallet.Views.AssetDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AtomicWallet.Controls"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:AssetDetailViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top-right icons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,16,0">
            <Path Data="{StaticResource IconGear}" Width="20" Height="20" Stretch="Uniform"
                  Fill="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0" />
            <Button Style="{StaticResource IconButton}" Command="{Binding CloseCommand}" Width="28" Height="28">
                <Path Data="{StaticResource IconClose}" Width="18" Height="18" Stretch="Uniform"
                      Fill="{DynamicResource TextSecondaryBrush}" />
            </Button>
        </StackPanel>

        <!-- Header + balance + actions -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Grid Width="34" Height="34">
                    <Border CornerRadius="17" Background="{Binding Coin.IconColor, Converter={StaticResource HexToBrush}}" />
                    <Image Source="{Binding Coin.LogoKey, Converter={StaticResource LogoImage}}"
                           Width="34" Height="34" RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
                <ComboBox Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="160"
                          Background="Transparent"
                          ItemsSource="{Binding Coins}" SelectedItem="{Binding SelectedSwitch}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="22" Height="22">
                                    <Border CornerRadius="11" Background="{Binding IconColor, Converter={StaticResource HexToBrush}}" />
                                    <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}" Width="22" Height="22"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Grid>
                                <TextBlock Text="{Binding Name}" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <TextBlock Text="{Binding Coin.Balance, StringFormat=0.####}" Style="{StaticResource Hero}" />
                <TextBlock Text="{Binding Coin.Ticker}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="20" VerticalAlignment="Bottom" Margin="8,0,0,4" />
            </StackPanel>
            <TextBlock HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource Fiat}">
                        <Binding Path="Coin.Value" />
                        <Binding Path="Symbol" Source="{StaticResource Fx}" />
                        <Binding Path="Rate" Source="{StaticResource Fx}" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="RECEIVE" Style="{StaticResource PillOutlined}" Width="150"
                        Command="{Binding ReceiveCommand}" />
                <Button Content="SEND" Style="{StaticResource PillOutlined}" Width="150" Margin="14,0,0,0"
                        Command="{Binding SendCommand}" />
                <Button Content="SWAP" Style="{StaticResource PillOutlined}" Width="150" Margin="14,0,0,0"
                        Command="{Binding SwapCommand}" />
                <Button Content="BUY" Style="{StaticResource PillOutlined}" Width="150" Margin="14,0,0,0"
                        Command="{Binding BuyCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- Tabs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,26,0,0">
            <Button Command="{Binding ShowTabCommand}" CommandParameter="0" Cursor="Hand" Margin="0,0,28,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel>
                            <TextBlock x:Name="t" Text="TRANSACTIONS" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Rectangle x:Name="u" Height="2" Margin="0,8,0,0" Fill="{DynamicResource AccentBlueBrush}"
                                       Visibility="Hidden" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="u" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Command="{Binding ShowTabCommand}" CommandParameter="1" Cursor="Hand" Margin="0,0,28,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel>
                            <TextBlock x:Name="t" Text="PRICE CHART" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Rectangle x:Name="u" Height="2" Margin="0,8,0,0" Fill="{DynamicResource AccentBlueBrush}"
                                       Visibility="Hidden" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="u" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Command="{Binding ShowTabCommand}" CommandParameter="2" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel>
                            <TextBlock x:Name="t" Text="ABOUT" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Rectangle x:Name="u" Height="2" Margin="0,8,0,0" Fill="{DynamicResource AccentBlueBrush}"
                                       Visibility="Hidden" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="2">
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="u" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Tab content -->
        <Grid Grid.Row="2" Margin="40,16,40,16">
            <Border Background="{DynamicResource BorderBrush}" Height="1" VerticalAlignment="Top" />

            <!-- Transactions (empty) -->
            <Grid Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=0}">
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                           Style="{StaticResource Caption}" FontSize="14"
                           Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <Run Text="Your " /><Run Text="{Binding Coin.Ticker, Mode=OneWay}" /><Run Text=" transactions will appear here" />
                </TextBlock>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0"
                              Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Transactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="60">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="34" Height="34" VerticalAlignment="Center">
                                        <Border CornerRadius="17" Background="{Binding IconColor, Converter={StaticResource HexToBrush}}" />
                                        <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}"
                                               Width="34" Height="34" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DirectionLabel}" FontWeight="Medium" />
                                        <TextBlock Text="{Binding Address}" Style="{StaticResource Caption}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="360" HorizontalAlignment="Left" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SignedAmount}" HorizontalAlignment="Right" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource NegativeBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsReceived}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.yyyy, HH:mm'}"
                                                   Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Price Chart -->
            <Grid Margin="0,20,0,0"
                  Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=1}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <StackPanel.Resources>
                            <Style x:Key="RangePill" TargetType="Button">
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                                <Setter Property="Command" Value="{Binding SelectRangeCommand}" />
                            </Style>
                        </StackPanel.Resources>
                        <Button Style="{StaticResource RangePill}" CommandParameter="24H">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,6" Background="Transparent">
                                        <TextBlock x:Name="t" Text="24H" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRange}" Value="24H">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource RangePill}" CommandParameter="1W">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,6" Background="Transparent">
                                        <TextBlock x:Name="t" Text="1W" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRange}" Value="1W">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource RangePill}" CommandParameter="1M">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,6" Background="Transparent">
                                        <TextBlock x:Name="t" Text="1M" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRange}" Value="1M">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource RangePill}" CommandParameter="1Y">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,6" Background="Transparent">
                                        <TextBlock x:Name="t" Text="1Y" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRange}" Value="1Y">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource RangePill}" CommandParameter="ALL">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,6" Background="Transparent">
                                        <TextBlock x:Name="t" Text="ALL" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRange}" Value="ALL">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Coin.Price, StringFormat=${0:N2}}" Style="{StaticResource Hero}"
                                   FontSize="26" HorizontalAlignment="Right" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding RangeLabel, StringFormat={}{0} }" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding RangeChange, Converter={StaticResource SignedPercent}}"
                                       Foreground="{Binding RangeChange, Converter={StaticResource ChangeBrush}}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <controls:AreaChart Grid.Row="1" Margin="0,16,0,0"
                                    Values="{Binding ChartSeries}"
                                    Stroke="{Binding Coin.SparkColor, Converter={StaticResource HexToBrush}}" />
            </Grid>

            <!-- About -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0"
                          Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=2}">
                <ItemsControl ItemsSource="{Binding AboutCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="220" Margin="8" CornerRadius="8" Background="{DynamicResource SurfaceBrush}">
                                <StackPanel>
                                    <Border Height="110" CornerRadius="8,8,0,0" Background="{DynamicResource SurfaceAltBrush}" />
                                    <TextBlock Text="{Binding}" Margin="12" TextWrapping="Wrap" FontSize="13" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
