<UserControl x:Class="AtomicWallet.Views.BuyCryptoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:views="clr-namespace:AtomicWallet.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:BuyCryptoViewModel}">
    <UserControl.Resources>
        <DataTemplate x:Key="CoinItem">
            <StackPanel Orientation="Horizontal">
                <Grid Width="22" Height="22">
                    <Border CornerRadius="11" Background="{Binding IconColor, Converter={StaticResource HexToBrush}}" />
                    <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}" Width="22" Height="22"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
                <TextBlock Text="{Binding Ticker}" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Medium" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Two-half tab bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding ShowBuyCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Buy crypto" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="1" Command="{Binding ShowHistoryCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Order History" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Buy crypto -->
        <Grid Grid.Row="1" Margin="60,40,60,0"
              Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=0}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Fiat + coin circles -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <views:UsFlag Grid.Column="0" Width="64" Height="64" HorizontalAlignment="Center" />
                <Grid Grid.Column="1" Width="64" Height="64">
                    <Border CornerRadius="32"
                            Background="{Binding ToCoin.IconColor, Converter={StaticResource HexToBrush}}">
                        <TextBlock Text="{Binding ToCoin.Ticker, Converter={StaticResource Initial}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White" FontWeight="Bold" FontSize="24" />
                    </Border>
                    <Image Source="{Binding ToCoin.LogoKey, Converter={StaticResource LogoImage}}"
                           Width="64" Height="64" RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
            </Grid>

            <!-- Inputs -->
            <Grid Grid.Row="1" Margin="0,28,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{DynamicResource AccentBlueBrush}" BorderThickness="0,0,0,1"
                        Padding="0,6">
                    <Grid>
                        <TextBox Style="{StaticResource UnderlineTextBox}" FontSize="22" Background="Transparent"
                                 Margin="0,0,70,0"
                                 Text="{Binding AmountUsdText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="USD" FontSize="22" FontWeight="Medium"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Path Grid.Column="1" Data="{StaticResource IconSwap}" Width="20" Height="20" Stretch="Uniform"
                      Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                      ToolTip="Type either amount — they convert both ways" />
                <Border Grid.Column="2" BorderBrush="{DynamicResource AccentBlueBrush}" BorderThickness="0,0,0,1"
                        Padding="0,6">
                    <Grid>
                        <TextBox Style="{StaticResource UnderlineTextBox}" FontSize="22" Background="Transparent"
                                 VerticalAlignment="Center" Margin="0,0,130,0"
                                 Text="{Binding AmountCryptoText, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox Width="120" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  ItemsSource="{Binding Coins}" SelectedItem="{Binding ToCoin}"
                                  ItemTemplate="{StaticResource CoinItem}" />
                    </Grid>
                </Border>
            </Grid>
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Bottom" Margin="0,0,0,-22">
                <TextBlock Text="Reward: " Style="{StaticResource Caption}" />
                <TextBlock Text="{Binding RewardText}" FontSize="12" FontWeight="Bold" />
            </StackPanel>

            <!-- Fees + CONTINUE -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,56,0,0">
                <TextBlock Text="5% fees (min 10 USD) are included in the price"
                           Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                <TextBlock Text="The average delivery time is 10 to 30 minutes"
                           Style="{StaticResource Caption}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                <Button Content="CONTINUE" Style="{StaticResource PillFilled}" Width="240" Margin="0,28,0,0"
                        Command="{Binding ContinueCommand}" />
            </StackPanel>

            <!-- Card logos -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                <TextBlock Text="VISA" FontWeight="Bold" FontStyle="Italic" FontSize="20"
                           Foreground="{DynamicResource TextFaintBrush}" />
                <Grid Margin="16,0,0,0">
                    <Ellipse Width="22" Height="22" Fill="#EB001B" Opacity="0.6" HorizontalAlignment="Left" />
                    <Ellipse Width="22" Height="22" Fill="#F79E1B" Opacity="0.6" Margin="14,0,0,0" />
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Order History -->
        <Grid Grid.Row="1"
              Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=1}">

            <!-- Empty state -->
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"
                       Text="Your orders will appear here">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Orders.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Order list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="40,18,40,18">
                <ItemsControl ItemsSource="{Binding Orders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
                                    Padding="18,14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Coin logo -->
                                    <Grid Grid.Column="0" Width="42" Height="42" VerticalAlignment="Center">
                                        <Border CornerRadius="21"
                                                Background="{Binding IconColor, Converter={StaticResource HexToBrush}}" />
                                        <TextBlock Text="{Binding Ticker, Converter={StaticResource Initial}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White" FontWeight="Bold" FontSize="14" />
                                        <Image Source="{Binding LogoKey, Converter={StaticResource LogoImage}}"
                                               Width="42" Height="42"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>

                                    <!-- Title + meta -->
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="15" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                                            <Border CornerRadius="8" Background="#17331F" Padding="9,2">
                                                <TextBlock Text="{Binding Status}" FontSize="11"
                                                           Foreground="{DynamicResource PositiveBrush}" />
                                            </Border>
                                            <TextBlock Text="{Binding PaymentMethod}" Style="{StaticResource Caption}"
                                                       Margin="10,0,0,0" VerticalAlignment="Center" />
                                            <Ellipse Width="3" Height="3" Margin="8,1,8,0" VerticalAlignment="Center"
                                                     Fill="{DynamicResource TextFaintBrush}" />
                                            <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.yyyy, HH:mm'}"
                                                       Style="{StaticResource Caption}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Amounts -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding CryptoText}" FontWeight="Medium" FontSize="15"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource PositiveBrush}" />
                                        <TextBlock Text="{Binding FiatText}" Style="{StaticResource Caption}"
                                                   HorizontalAlignment="Right" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
