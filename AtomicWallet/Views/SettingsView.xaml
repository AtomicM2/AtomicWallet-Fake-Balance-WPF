<UserControl x:Class="AtomicWallet.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Three-thirds tab bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding ShowMembershipCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Membership" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="1" Command="{Binding ShowSecurityCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Security" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Command="{Binding ShowPrivateKeysCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource TabBarBrush}">
                            <TextBlock Text="Private Keys" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" x:Name="t" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="2">
                                <Setter TargetName="b" Property="Background" Value="Transparent" />
                                <Setter TargetName="t" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="t" Property="FontWeight" Value="Medium" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Membership (placeholder) -->
        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Caption}"
                   FontSize="14" Text="Membership"
                   Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=0}" />

        <!-- Security -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0"
                    Width="500"
                    Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=1}">
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="Before changing your password, click Private Keys in the top panel and write down your 12-word backup phrase. This will help you restore your wallet if you forget your new password." />

            <Grid Margin="0,40,0,0">
                <PasswordBox x:Name="OldPwBox" Style="{StaticResource UnderlinePassword}"
                             PasswordChanged="OldPwBox_PasswordChanged" />
                <TextBlock x:Name="OldPwPh" Text="Old password" IsHitTestVisible="False" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
            <Grid Margin="0,24,0,0">
                <PasswordBox x:Name="NewPwBox" Style="{StaticResource UnderlinePassword}"
                             PasswordChanged="NewPwBox_PasswordChanged" />
                <TextBlock x:Name="NewPwPh" Text="New password" IsHitTestVisible="False" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Strength:" Style="{StaticResource Caption}" />
                <Path Data="{StaticResource IconInfo}" Width="12" Height="12" Stretch="Uniform"
                      Fill="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <Grid Margin="0,16,0,0">
                <PasswordBox x:Name="RepeatPwBox" Style="{StaticResource UnderlinePassword}"
                             PasswordChanged="RepeatPwBox_PasswordChanged" />
                <TextBlock x:Name="RepeatPwPh" Text="Repeat New password" IsHitTestVisible="False" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
            <Button Content="CHANGE PASSWORD" Style="{StaticResource PillFilled}" Width="240" Margin="0,32,0,0"
                    HorizontalAlignment="Center" Command="{Binding ChangePasswordCommand}" />
        </StackPanel>

        <!-- Private Keys -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0"
                    Width="560"
                    Visibility="{Binding SelectedTab, Converter={StaticResource EqualsToVis}, ConverterParameter=2}">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M7 2v11h3v9l7-12h-4l4-8z" Width="26" Height="26" Stretch="Uniform"
                          Fill="{DynamicResource GoldBrush}" VerticalAlignment="Top" />
                    <StackPanel Margin="14,0,0,0">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFaintBrush}"
                                   Text="Never share your 12-word backup phrase and private keys with anyone. Never enter your info on web wallets, online forms, or other websites. Otherwise, you may risk losing your money." />
                        <TextBlock Text="How do I protect my wallet?" Foreground="{DynamicResource AccentBlueBrush}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Grid Margin="0,40,0,0">
                <PasswordBox x:Name="KeysPwBox" Style="{StaticResource UnderlinePassword}"
                             PasswordChanged="KeysPwBox_PasswordChanged" />
                <TextBlock x:Name="KeysPwPh" Text="Password" IsHitTestVisible="False" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </Grid>
            <Button Content="SHOW PRIVATE KEYS" Style="{StaticResource PillFilled}" Width="240" Margin="0,32,0,0"
                    HorizontalAlignment="Center" Command="{Binding ShowKeysCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
