<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Roboto with graceful fallback. Type scale & weights per docs/atomic-spec.md. -->
    <FontFamily x:Key="AppFont">Roboto, Segoe UI</FontFamily>

    <!-- Type scale -->
    <sys:Double x:Key="FsCaption">12</sys:Double>
    <sys:Double x:Key="FsBody">14</sys:Double>
    <sys:Double x:Key="FsLabel">16</sys:Double>
    <sys:Double x:Key="FsHeading">18</sys:Double>
    <sys:Double x:Key="FsAmount">24</sys:Double>
    <sys:Double x:Key="FsHero">32</sys:Double>

    <!-- Default TextBlock: Roboto, primary color, 14/Medium-ish -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="{StaticResource FsBody}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <!-- Named text styles -->
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="{StaticResource FsCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="ColumnHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="{StaticResource FsCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="Heading" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="{StaticResource FsHeading}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="Hero" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="{StaticResource FsHero}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

</ResourceDictionary>
