<UserControl x:Class="AtomicWallet.Views.AssetReceiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtomicWallet.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ReceiveViewModel}">
    <Grid>
        <!-- Close -->
        <Button Style="{StaticResource IconButton}" Command="{Binding CloseCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,16,0" Width="28" Height="28">
            <Path Data="{StaticResource IconClose}" Width="18" Height="18" Stretch="Uniform"
                  Fill="{DynamicResource TextSecondaryBrush}" />
        </Button>

        <StackPanel HorizontalAlignment="Center" Margin="0,28,0,0">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Grid Width="34" Height="34">
                    <Border CornerRadius="17" Background="{Binding Coin.IconColor, Converter={StaticResource HexToBrush}}" />
                    <Image Source="{Binding Coin.LogoKey, Converter={StaticResource LogoImage}}"
                           Width="34" Height="34" RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Coin.Name}" FontSize="18" FontWeight="Medium" />
                    <Rectangle Height="1" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1"
                               StrokeDashArray="2 2" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="Your " /><Run Text="{Binding Coin.Ticker, Mode=OneWay}" /><Run Text=" Address" />
            </TextBlock>

            <!-- QR -->
            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,16,0,0"
                    HorizontalAlignment="Center">
                <Image Source="{Binding QrImage}" Width="180" Height="180"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
            </Border>

            <TextBlock Text="{Binding Address}" HorizontalAlignment="Center" Margin="0,16,0,0"
                       Foreground="{DynamicResource PositiveBrush}" FontFamily="Consolas" />

            <Button Content="Copy" Style="{StaticResource PillOutlined}" Width="200" Margin="0,20,0,0"
                    Command="{Binding CopyCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
